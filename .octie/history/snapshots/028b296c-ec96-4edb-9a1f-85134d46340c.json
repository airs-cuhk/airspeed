    "0e4d9258-fc7d-4e63-8954-f112acd34df2": {
      "id": "0e4d9258-fc7d-4e63-8954-f112acd34df2",
      "title": "Implement HDF5 to Parquet converter with per-stream files",
      "description": "Build convert_h5_to_parquet.py that writes each AIRS stream to a separate .parquet file. Vector streams: schema (timestamp_ns: uint64, dim_0..dim_N: float32) with Zstd compression level 3. Image streams: schema (timestamp_ns: uint64, jpeg_bytes: binary). Include --consolidate flag to merge all streams into one Parquet file with a stream_name column. Validate: row count matches HDF5, column count matches dims, JPEG roundtrip identical, no NaN/Inf leakage.",
      "status": "blocked",
      "priority": "top",
      "success_criteria": [
        {
          "id": "77e6c236-a25a-4dc7-abef-c3ec676a26de",

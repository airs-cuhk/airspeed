    "eb593dcb-f20c-4a59-b0d1-2468544478d7": {
      "id": "eb593dcb-f20c-4a59-b0d1-2468544478d7",
      "title": "Implement HDF5 to JSON Lines converter with output validation",
      "description": "Build convert_h5_to_jsonl.py that reads the AIRS HDF5 file and writes one JSON line per frame. Must handle async streams: each line is a frame from the fastest stream (VR@1119), other streams include nearest-timestamp values. Include --streams filter to convert individual streams. Validate output: check line count matches frame count, verify JPEG base64 roundtrip, check timestamps monotonic.",
      "status": "ready",
      "priority": "top",
      "success_criteria": [
        {
          "id": "bc5ead87-b289-43ac-b11c-1c4e9853dbf1",
          "text": "convert_h5_to_jsonl.py converts target HDF5 to .jsonl with 1119 lines",
          "completed": false
        },
        {
          "id": "68502eec-399d-4209-8872-cef096cbdd5d",
          "text": "Output .jsonl can be re-read with json.loads() on every line",
          "completed": false
        },
        {
          "id": "6c920891-17ae-4837-856e-80388baf0a47",
          "text": "--streams vr_head_pose converts only that single stream",
          "completed": false
        },
        {
          "id": "5c19df91-ef3c-4039-81ec-9364bf9c241b",
          "text": "JPEG base64 roundtrip produces identical bytes to source HDF5",
          "completed": false
        },
        {
          "id": "94d18bf8-d99b-4eff-a912-e704d1db385f",
          "text": "Timestamps in output are strictly monotonic",
          "completed": false
        }
      ],
      "deliverables": [
        {
          "id": "7e437bcc-68a2-4cbe-9167-88edce9db88a",
          "text": "convert/tools/convert_h5_to_jsonl.py",
